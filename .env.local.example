# Supabase - get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public read key. New projects use "Publishable key" (sb_publishable_...); older ones use "anon".
# Either variable name works - set whichever matches your key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Secret key (admin, bypasses RLS) - REQUIRED for the data scripts to write.
# New projects use "Secret key" (sb_secret_...); older ones use "service_role". Either name works.
SUPABASE_SECRET_KEY=sb_secret_xxx
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenRouter - get from https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# News source for "informed" briefs. Optional but recommended for reliable history.
# Free key at https://newsapi.org (Developer tier: last 30 days, 100 req/day).
# If unset, build-briefs falls back to GDELT (free, no key, but rate-limits hard).
# NEWS_API_KEY=your-newsapi-org-key

# Optional: override which model writes run digests.
# Precedence: this env var > src/config/survey-config.json "models.digestAuthor" > first id in run.model_list.
# DIGEST_AUTHOR_MODEL_ID=anthropic/claude-haiku-4-5
